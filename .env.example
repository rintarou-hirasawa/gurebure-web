# 新しい Supabase プロジェクト作成後、ダッシュボードから値をコピーして .env に貼り付けてください。
# このファイルを .env にコピーして編集しても構いません。

# Project Settings → API（または Connect の .env 例）
# 値は従来の anon（eyJ...）でも、新しい publishable（sb_publishable_...）でも可
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# npm run db:migrate または db:sql 用（任意）
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# カード画像: public/card_illustrations/ に「カード名」と同じファイル名で .jpg（なければ .png）を置く

# Google ログイン: Supabase → Authentication → Providers → Google を有効化し、
# Google Cloud Console の OAuth クライアント ID/シークレットを貼る。
# Redirect URLs に https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback と
# 開発用 http://localhost:5173/** を追加。
